{
  "$schema": "https://json-schema.org/draft/07/schema",
  "version": "1",
  "type": "object",
  "required": ["projectName", "projectType", "language"],
  "properties": {
    "projectName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "kebab-case project name"
    },
    "description": {
      "type": "string",
      "description": "one-line project description"
    },
    "date": {
      "type": "string",
      "description": "today's date in YYYY-MM-DD format, auto-set by scaffold"
    },
    "projectType": {
      "enum": ["monorepo", "single-app", "library", "cli-tool"],
      "description": "project structure type"
    },
    "language": {
      "enum": ["typescript"],
      "description": "primary language"
    },
    "modelCapability": {
      "enum": ["capable", "less-capable"],
      "default": "capable",
      "description": "coding agent model capability: capable (comprehensive docs with cross-refs), less-capable (essential docs with inline rules)"
    },
    "domainComplexity": {
      "enum": ["single-domain", "multi-domain"],
      "default": "single-domain",
      "description": "single-domain (<30 docs) uses flat structure, multi-domain uses folder-based"
    },
    "aiRuntime": {
      "enum": ["mastra", "none"],
      "default": "none"
    },
    "database": {
      "enum": ["postgresql", "sqlite", "mongodb", "none"],
      "default": "none"
    },
    "auth": {
      "enum": ["clerk", "nextauth", "none"],
      "default": "none"
    },
    "deployment": {
      "enum": ["docker", "none"],
      "default": "none"
    },
    "ci": {
      "enum": ["local", "github-actions"],
      "default": "local",
      "description": "local (lefthook pre-push only) or github-actions (CI workflow)"
    },
    "openSource": {
      "type": "boolean",
      "default": false
    },
    "multiTenant": {
      "type": "boolean",
      "default": false
    },
    "preserveResearchData": {
      "type": "boolean",
      "default": true,
      "description": "keep .firecrawl/ and scraped data in git for future research"
    },
    "packageManager": {
      "enum": ["pnpm", "npm", "yarn"],
      "default": "pnpm",
      "description": "only used when language=typescript"
    },
    "toolAliases": {
      "type": "array",
      "items": { "enum": ["claude", "cline", "cursor", "codex", "kilocode", "roo"] },
      "default": [],
      "description": "create symlinks for these tools (CLAUDE.md, .clinerules, etc.)"
    },
    "deferredDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "timing"],
        "properties": {
          "question": { "type": "string" },
          "timing": { "type": "string", "description": "before what milestone" },
          "risk": { "enum": ["high", "medium", "low"], "default": "medium" }
        }
      },
      "default": [],
      "description": "decisions deferred during the grill phase"
    }
  }
}
