# ==== INFRASTRUCTURE ===========================================================
{{#if db_postgres}}
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB={{projectName}}
{{/if}}
{{#if db_sqlite}}
DATABASE_URL=file:./data/{{projectName}}.db
{{/if}}
{{#if db_mongo}}
MONGODB_URI=mongodb://localhost:27017/{{projectName}}
{{/if}}

# ==== SERVER ===================================================================
PORT=3000
NODE_ENV=development

# ==== AUTH =====================================================================
{{#if auth_clerk}}
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
{{/if}}
{{#if auth_nextauth}}
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_64
NEXTAUTH_URL=http://localhost:3000
{{/if}}

# ==== DEPLOYMENT ===============================================================
{{#if deploy_docker}}
IMAGE_TAG=latest
{{/if}}

# ==== OBSERVABILITY ============================================================
LOG_LEVEL=info
