{{#if ci_github}}
name: CI
on: [push, pull_request]

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: "pnpm"
      - run: pnpm install
      - run: pnpm run lint
      - run: pnpm run typecheck
      - run: pnpm run test
{{else}}
# CI runs locally via lefthook pre-push hooks
# Quality gates are enforced at: lint > typecheck > validate-docs > check-sizes > test
# See lefthook.yml for the full configuration
{{/if}}
